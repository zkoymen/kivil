{
  "$schema": "https://raw.githubusercontent.com/neutralinojs/neutralinojs/main/schemas/neutralino.config.schema.json",
  "applicationId": "com.zkoymen.kivil",
  "version": "0.1.0",
  "applicationIcon": "public/appIcon.png",
  "defaultMode": "window",
  "port": 44735,
  "documentRoot": "/dist/",
  "url": "/",
  "enableServer": true,
  "enableNativeAPI": true,
  "tokenSecurity": "one-time",
  "nativeAllowList": [
    "window.getSize",
    "window.getPosition",
    "window.setAlwaysOnTop",
    "window.setSize",
    "window.move",
    "window.center",
    "window.focus"
  ],
  "logging": {
    "enabled": true,
    "writeToLogFile": false
  },
  "modes": {
    "window": {
      "title": "Kıvıl",
      "width": 1780,
      "height": 1200,
      "minWidth": 1180,
      "minHeight": 760,
      "center": true,
      "fullScreen": false,
      "alwaysOnTop": false,
      "icon": "/dist/appIcon.png",
      "enableInspector": false,
      "borderless": false,
      "maximize": false,
      "hidden": false,
      "resizable": true,
      "exitProcessOnClose": true
    }
  },
  "cli": {
    "binaryName": "kivil",
    "resourcesPath": "/dist/",
    "extensionsPath": "/extensions/",
    "binaryVersion": "6.8.0",
    "clientVersion": "6.8.0"
  }
}
