{
  "$schema": "https://raw.githubusercontent.com/neutralinojs/neutralinojs/main/schemas/neutralino.config.schema.json",
  "applicationId": "com.zkoymen.kivil",
  "version": "0.1.0",
  "defaultMode": "window",
  "port": 0,
  "documentRoot": "/dist/",
  "url": "/",
  "enableServer": true,
  "enableNativeAPI": true,
  "tokenSecurity": "one-time",
  "nativeAllowList": [
    "app.exit",
    "window.minimize",
    "window.maximize",
    "window.unmaximize",
    "window.isMaximized",
    "window.setDraggableRegion"
  ],
  "logging": {
    "enabled": true,
    "writeToLogFile": false
  },
  "modes": {
    "window": {
      "title": "Kıvıl",
      "width": 1060,
      "height": 720,
      "minWidth": 920,
      "minHeight": 680,
      "x": 120,
      "y": 80,
      "center": false,
      "fullScreen": false,
      "alwaysOnTop": false,
      "icon": "/dist/appIcon.png",
      "enableInspector": false,
      "borderless": true,
      "maximize": false,
      "hidden": false,
      "resizable": true,
      "injectGlobals": true,
      "injectClientLibrary": true,
      "useSavedState": false,
      "exitProcessOnClose": true
    }
  },
  "cli": {
    "binaryName": "kivil",
    "resourcesPath": "/dist/",
    "extensionsPath": "/extensions/",
    "binaryVersion": "6.8.0",
    "clientVersion": "6.8.0"
  }
}
